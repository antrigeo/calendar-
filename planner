// ── AVATAR ───────────────────────────────────────────────────────────────────
function Avatar({ initials, color, size=36 }) {
  return (
    <div style={{ width:size, height:size, borderRadius:"50%", background:color,
      display:"flex", alignItems:"center", justifyContent:"center",
      fontSize:size*0.33, fontWeight:700, color:"#fff", flexShrink:0 }}>
      {initials}
    </div>
  );
}

// ── STATUS DOT ────────────────────────────────────────────────────────────────
function StatusDot({ status, size=8 }) {
  const s = STATUS_OPTIONS.find(x=>x.key===status) || STATUS_OPTIONS[0];
  return <div style={{ width:size, height:size, borderRadius:"50%", background:s.color, border:`2px solid ${C.bg}`, flexShrink:0 }} />;
}

// ── NOTIFICATION TOAST ────────────────────────────────────────────────────────
function Toast({ notif }) {
  if (!notif) return null;
  const bg = notif.type==="danger" ? C.danger : notif.type==="warning" ? C.warning : C.success;
  return (
    <div style={{ position:"fixed", top:20, right:20, zIndex:9999,
      background:bg, color:"#fff", padding:"12px 18px", borderRadius:12,
      fontSize:13, fontWeight:500, boxShadow:"0 8px 32px rgba(0,0,0,0.4)",
      maxWidth:280, animation:"slideIn 0.2s ease" }}>
      {notif.msg}
    </div>
  );
}

