        <input value={msg} onChange={e=>setMsg(e.target.value)} placeholder="Μήνυμα (προαιρετικό)..." style={{ ...inputSt, marginBottom:14 }}/>
        <div style={{ display:"flex", gap:10 }}>
          <button onClick={()=>setShowInviteModal(null)} style={{ ...btnGhost, flex:1 }}>Άκυρο</button>
          <button onClick={()=>{ if(!selEv) return; toast(`Invite στάλθηκε στον/ην ${showInviteModal.name}!`); setShowInviteModal(null); }} style={{ ...btn, flex:2, opacity:selEv?1:0.5 }}>Αποστολή Invite</button>
        </div>
      </Modal>
    );
  };

  // ── MEETUP PROPOSAL MODAL (send) ──────────────────────────────────────────
  const MeetupModal = () => {
    const [step, setStep]         = useState(1); // 1=type, 2=slots, 3=confirm
    const [mType, setMType]       = useState(MEETUP_TYPES[0]);
    const [msg, setMsg]           = useState("");
    const [slots, setSlots]       = useState([
      { id:"n1", date:"", time:"", picked:false },
      { id:"n2", date:"", time:"", picked:false },
    ]);

    const addSlot = () => {
      if (slots.length >= 5) return;
      setSlots([...slots, { id:`n${Date.now()}`, date:"", time:"", picked:false }]);
    };
    const removeSlot = id => setSlots(slots.filter(s=>s.id!==id));
    const updateSlot = (id, field, val) => setSlots(slots.map(s=>s.id===id?{...s,[field]:val}:s));

    const validSlots = slots.filter(s=>s.date && s.time);
    const canSend = validSlots.length >= 1;

    const send = () => {
      const prop = {
        id: Date.now(), fromId:0, toId:showMeetup.id,
        type:mType.type, label:mType.label, icon:mType.icon,
        message:msg, status:"sent",
        slots: validSlots,
      };
      setProposals([...proposals, prop]);
      setShowMeetup(null);
      toast(`Πρόταση στάλθηκε στον/ην ${showMeetup.name}!`);
    };

    return (
      <Modal onClose={()=>setShowMeetup(null)} title={`Πρόταση Συνάντησης — ${showMeetup?.name}`} width={440}>
        {/* Step indicator */}
        <div style={{ display:"flex", gap:6, marginBottom:20 }}>
          {["Τύπος","Ημερομηνίες","Επιβεβαίωση"].map((s,i)=>(
            <div key={i} style={{ flex:1, height:3, borderRadius:3, background: step>i ? C.accent : C.border, transition:"background 0.2s" }}/>
          ))}
        </div>

        {step===1 && (
          <div>
            <div style={{ fontSize:13, color:C.textMuted, marginBottom:12 }}>Για τι είδους συνάντηση;</div>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:16 }}>
              {MEETUP_TYPES.map(t=>(
                <button key={t.label} onClick={()=>setMType(t)} style={{
                  display:"flex", alignItems:"center", gap:10, padding:"12px 14px",
                  borderRadius:12, border:`2px solid ${mType.label===t.label?C.accent:C.border}`,
                  background:mType.label===t.label?C.accentMuted:C.bg, cursor:"pointer",
                }}>
                  <span style={{ fontSize:20 }}>{t.icon}</span>
                  <span style={{ fontSize:13, fontWeight:500, color:C.text }}>{t.label}</span>
                </button>
              ))}
            </div>
            <textarea value={msg} onChange={e=>setMsg(e.target.value)}
              placeholder={`Μήνυμα στον/ην ${showMeetup?.name}... (προαιρετικό)`}
              rows={2} style={{ ...inputSt, resize:"none", lineHeight:1.5 }}/>
            <button onClick={()=>setStep(2)} style={{ ...btn, width:"100%", marginTop:14 }}>Επόμενο →</button>
          </div>
        )}

        {step===2 && (
          <div>
            <div style={{ fontSize:13, color:C.textMuted, marginBottom:12 }}>
              Πρόσθεσε 1–5 επιλογές ημερομηνίας. Ο/Η {showMeetup?.name} θα επιλέξει ποια τον/την βολεύει.
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:10, marginBottom:12 }}>
              {slots.map((slot,i)=>(
                <div key={slot.id} style={{ display:"flex", gap:8, alignItems:"center" }}>
                  <div style={{ width:24, height:24, borderRadius:"50%", background:C.accentMuted, display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:700, color:C.accentLight, flexShrink:0 }}>{i+1}</div>
                  <input type="date" value={slot.date} onChange={e=>updateSlot(slot.id,"date",e.target.value)}
                    style={{ ...inputSt, flex:1 }} min="2026-06-16"/>
                  <input type="time" value={slot.time} onChange={e=>updateSlot(slot.id,"time",e.target.value)}
                    style={{ ...inputSt, width:100 }}/>
                  {slots.length>1 && (
                    <button onClick={()=>removeSlot(slot.id)} style={{ background:"none", border:"none", color:C.textDim, cursor:"pointer", fontSize:18, flexShrink:0 }}>×</button>
                  )}
                </div>
              ))}
            </div>
            {slots.length<5 && (
              <button onClick={addSlot} style={{ ...btnGhost, width:"100%", fontSize:12, padding:"8px" }}>+ Πρόσθεσε επιλογή</button>
            )}
            <div style={{ display:"flex", gap:10, marginTop:14 }}>
              <button onClick={()=>setStep(1)} style={{ ...btnGhost, flex:1 }}>← Πίσω</button>
              <button onClick={()=>setStep(3)} disabled={!canSend} style={{ ...btn, flex:2, opacity:canSend?1:0.5 }}>Επόμενο →</button>
            </div>
          </div>
        )}

        {step===3 && (
          <div>
            <div style={{ fontSize:13, color:C.textMuted, marginBottom:14 }}>Επιβεβαίωση πρότασης</div>
            <div style={{ background:C.bg, borderRadius:12, padding:16, border:`1px solid ${C.border}`, marginBottom:14 }}>
              <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:12 }}>
                <span style={{ fontSize:24 }}>{mType.icon}</span>
                <div>
                  <div style={{ fontWeight:600 }}>{mType.label}</div>
                  <div style={{ fontSize:12, color:C.textMuted }}>με {showMeetup?.name} {showMeetup?.surname}</div>
                </div>
              </div>
              {msg && <div style={{ fontSize:12, color:C.textMuted, fontStyle:"italic", marginBottom:10 }}>"{msg}"</div>}
              <div style={{ fontSize:12, color:C.textMuted, marginBottom:6 }}>Επιλογές ημερομηνίας:</div>
              {validSlots.map((s,i)=>(
                <div key={s.id} style={{ display:"flex", alignItems:"center", gap:8, padding:"6px 0", borderBottom: i<validSlots.length-1?`1px solid ${C.border}`:"none" }}>
                  <span style={{ fontSize:12, color:C.accentLight, fontWeight:600 }}>{i+1}.</span>
                  <span style={{ fontSize:13 }}>{s.date} — {s.time}</span>
                </div>
              ))}
            </div>
            <div style={{ display:"flex", gap:10 }}>
              <button onClick={()=>setStep(2)} style={{ ...btnGhost, flex:1 }}>← Πίσω</button>
              <button onClick={send} style={{ ...btn, flex:2 }}>✓ Αποστολή</button>
            </div>
          </div>
        )}
      </Modal>
    );
  };

  // ── PROPOSAL REPLY MODAL (receive) ────────────────────────────────────────
  const ProposalReplyModal = () => {
    const p = showProposalReply;
    const sender = ALL_USERS.find(u=>u.id===p?.fromId);
    const [picked, setPicked] = useState(null);

    const accept = () => {
      if (!picked) return;
      const slot = p.slots.find(s=>s.id===picked);
      // Add to calendar
      setEvents(ev=>[...ev, {
        id:Date.now(), title:`${p.icon} ${p.label} με ${sender?.name}`,
        date:slot.date, time:slot.time, type:p.type, shared:[p.fromId], reminder:true
      }]);
      setProposals(proposals.map(pr=>pr.id===p.id?{...pr,status:"accepted"}:pr));
      setShowProposalReply(null);
      toast(`Συνάντηση επιβεβαιώθηκε! Προστέθηκε στο ημερολόγιο.`);
    };

    const decline = () => {
      setProposals(proposals.map(pr=>pr.id===p.id?{...pr,status:"declined"}:pr));
      setShowProposalReply(null);
      toast("Αρνήθηκες την πρόταση","warning");
    };

    if (!p || !sender) return null;
    return (
      <Modal onClose={()=>setShowProposalReply(null)} title="Πρόταση Συνάντησης" width={420}>
        <div style={{ display:"flex", alignItems:"center", gap:12, marginBottom:16, padding:"12px 14px", background:C.bg, borderRadius:12, border:`1px solid ${C.border}` }}>
          <div style={{ position:"relative" }}>
            <Avatar initials={sender.avatar} color={sender.color} size={44}/>
            <div style={{ position:"absolute", bottom:0, right:0 }}><StatusDot status={sender.status} size={10}/></div>
          </div>
          <div>
            <div style={{ fontWeight:600 }}>{sender.name} {sender.surname}</div>
            <div style={{ fontSize:12, color:C.textMuted }}>προτείνει {p.icon} {p.label}</div>
          </div>
        </div>
        {p.message && (
          <div style={{ fontSize:13, color:C.text, background:C.surfaceHigh, borderRadius:10, padding:"10px 14px", marginBottom:14, fontStyle:"italic" }}>"{p.message}"</div>
        )}
        <div style={{ fontSize:13, fontWeight:600, marginBottom:10 }}>Επίλεξε ημερομηνία που σε βολεύει:</div>
        <div style={{ display:"flex", flexDirection:"column", gap:8, marginBottom:16 }}>
          {p.slots.map((slot,i)=>(
            <button key={slot.id} onClick={()=>setPicked(slot.id===picked?null:slot.id)} style={{
              display:"flex", alignItems:"center", gap:12, padding:"14px 16px",
              borderRadius:12, border:`2px solid ${picked===slot.id?C.accent:C.border}`,
              background:picked===slot.id?C.accentMuted:C.bg, cursor:"pointer", textAlign:"left",
            }}>
              <div style={{ width:28, height:28, borderRadius:"50%", background:picked===slot.id?C.accent:C.surfaceHigh, display:"flex", alignItems:"center", justifyContent:"center", fontSize:12, fontWeight:700, color:picked===slot.id?"#fff":C.textMuted, flexShrink:0 }}>{i+1}</div>
              <div>
                <div style={{ fontSize:14, fontWeight:500, color:C.text }}>{slot.date}</div>
                <div style={{ fontSize:12, color:C.textMuted }}>⏰ {slot.time}</div>
              </div>
              {picked===slot.id && <span style={{ marginLeft:"auto", color:C.accent, fontSize:16 }}>✓</span>}
            </button>
          ))}
        </div>
        <div style={{ display:"flex", gap:10 }}>
          <button onClick={decline} style={{ ...btnGhost, flex:1 }}>✕ Άρνηση</button>
          <button onClick={accept} disabled={!picked} style={{ ...btn, flex:2, opacity:picked?1:0.5 }}>✓ Επιβεβαίωση</button>
        </div>
      </Modal>
    );
  };

  // ── GENERIC MODAL WRAPPER ──────────────────────────────────────────────────
  function Modal({ onClose, title, width=400, children }) {
    return (
      <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.75)", zIndex:1000, display:"flex", alignItems:"center", justifyContent:"center", padding:16 }} onClick={e=>{ if(e.target===e.currentTarget) onClose(); }}>
        <div style={{ background:C.surface, borderRadius:16, padding:24, width:"100%", maxWidth:width, border:`1px solid ${C.border}`, maxHeight:"90vh", overflowY:"auto" }}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
            <div style={{ fontWeight:700, fontSize:16 }}>{title}</div>
            <button onClick={onClose} style={{ background:"none", border:"none", cursor:"pointer", color:C.textMuted, fontSize:20, lineHeight:1 }}>×</button>
          </div>
          {children}
        </div>
      </div>
    );
  }

  // ── RENDER ─────────────────────────────────────────────────────────────────
  const tabContent = { calendar:<CalendarTab/>, week:<WeekTab/>, friends:<FriendsTab/>, reminders:<RemindersTab/> };

  return (
    <div style={{ minHeight:"100vh", background:C.bg, color:C.text, fontFamily:"'Inter','Segoe UI',sans-serif", display:"flex" }}>
      {!isMobile && <Sidebar/>}
      <div style={{ flex:1, display:"flex", flexDirection:"column", minWidth:0 }}>
        {isMobile && <MobileHeader/>}
        <main style={{ flex:1, padding: isMobile?"16px 16px 80px":"24px", overflowY:"auto" }}>
          {tabContent[tab]}
        </main>
        {isMobile && <BottomNav/>}
      </div>

      {showProfile   && <ProfileModal/>}
      {showAdd       && <AddEventModal/>}
      {showShare     && <ShareModal/>}
      {showInviteModal && <InviteModal/>}
      {showMeetup    && <MeetupModal/>}
      {showProposalReply && <ProposalReplyModal/>}
      <Toast notif={notif}/>

      <style>{`
        * { box-sizing:border-box; margin:0; padding:0; }
        ::-webkit-scrollbar { width:4px; }
        ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background:${C.border}; border-radius:4px; }
        @keyframes slideIn { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:none; } }
        input[type=time]::-webkit-calendar-picker-indicator { filter:invert(1) opacity(0.4); }
      `}</style>
    </div>
  );
}
